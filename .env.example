# ============================================================
# OpenRNG Environment Configuration
# Copy to .env and fill in values — never commit .env to git
# ============================================================

# Server
NODE_ENV=development
PORT=3000
API_SECRET=your-api-secret-here-min-32-chars

# Database (Railway provides this automatically on deploy)
DATABASE_URL=postgresql://user:password@localhost:5432/openrng

# Blockchain — Polygon Amoy Testnet
# Get free MATIC from: https://faucet.polygon.technology/
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_CHAIN_ID=80002
# Your deployer wallet private key — NEVER share this
DEPLOYER_PRIVATE_KEY=0xyour-private-key-here
# After deploying the contract, paste address here
MERKLE_ANCHOR_CONTRACT=0x0000000000000000000000000000000000000000

# VDF Configuration
VDF_T_SECONDS=4
VDF_WORKERS=3

# Batch Configuration  
BATCH_SIZE=65536
POOL_REFILL_THRESHOLD=0.35
MAX_CONCURRENT_BATCHES=8

# AI Agents (Claude API)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Logging
LOG_LEVEL=info
